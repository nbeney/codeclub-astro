---
import P5PageLayout from '@layouts/P5PageLayout.astro';

const title = "P5 - Reference";
const heading = "P5 library - Reference";
---

<P5PageLayout title={title} heading={heading} showToc={false} showP5={false}>
    <h2>CONST-FLOAT (7)</h2>

    <pre><code class="language-python">DEG_TO_RAD = 0.0174532925199433
RAD_TO_DEG = 57.29577951308232
QUARTER_PI = 0.7853981633974483
HALF_PI = 1.570796326794897
PI = 3.141592653589793
TWO_PI = 6.283185307179586
TAU = 6.283185307179586</code></pre>

    <h2>CONST-INT (21)</h2>

    <pre><code class="language-python">A: ALT
B: BACKSPACE
C: CONTROL
D: DELETE, DOWN_ARROW
E: ENTER, ESCAPE
L: LEFT_ARROW, LINES, LINE_LOOP, LINE_STRIP
O: OPTION
P: POINTS
R: RETURN, RIGHT_ARROW
S: SHIFT
T: TAB, TRIANGLES, TRIANGLE_FAN, TRIANGLE_STRIP
U: UP_ARROW</code></pre>

    <h2>CONST-STR (83)</h2>

    <pre><code class="language-python">A: ADD, ARROW, AUTO, AXES
B: BASELINE, BEVEL, BEZIER, BLEND, BLUR, BOLD, BOLDITALIC, BOTTOM, BURN
C: CENTER, CHORD, CLAMP, CLOSE, CORNER, CORNERS, CROSS, CURVE
